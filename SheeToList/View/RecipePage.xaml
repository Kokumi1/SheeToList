<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SheeToList.View.RecipePage"
             x:Name="RecipePageUI">

    <ContentPage.Resources>
        <Style x:Key="ImageLikeButton" TargetType="ImageButton">
            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderWidth" Value="1"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Aspect" Value="AspectFit"/>
            <Setter Property="HorizontalOptions" Value="Fill"/>
            <Setter Property="VerticalOptions" Value="Fill"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="20,90,*,Auto,50" Padding="30,0">

        <Label Text="{Binding RecetteTitle}" FontSize="Title" TextColor="{StaticResource PrimaryDark}" FontAttributes="Bold"
               Grid.Row="1" VerticalOptions="Center">
            <Label.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding BindingContext.EditRecipeNameCommand, Source={x:Reference RecipePageUI}}"
                    />
            </Label.GestureRecognizers>
        </Label>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout  Spacing="25">
                <ActivityIndicator
             IsRunning="{Binding IsLoading}"
             IsVisible="{Binding IsLoading}"
             Color="{StaticResource Primary}"
             HorizontalOptions="Center"
             VerticalOptions="Center"
          />
                <CollectionView x:Name="ingredientList"
          ItemsSource="{Binding RecipeIngredientList}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10" ColumnDefinitions="70*,20*,30*,20*,2*" MaximumHeightRequest="70">

                                <Label Text="{Binding Name}"  VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer 
                                            Command="{Binding BindingContext.EditItemCommand, Source={x:Reference ingredientList}}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Text="{Binding Categorie}" VerticalOptions="Center" Grid.Column="2">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.EditItemCommand, Source={x:Reference ingredientList}}"
                                            CommandParameter="{Binding .}"
                                            />
                                    </Label.GestureRecognizers>
                                </Label>

                                <ImageButton 
                             Command="{Binding BindingContext.DeleteItemCommand, Source={x:Reference ingredientList}}"
                             CommandParameter="{Binding .}"
                             Source="trash.png"
                             Style="{StaticResource ImageLikeButton}"
                             Grid.Column="3"
                             />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Button
         Command="{Binding AddItemCommand}"
         Text="+"
         Grid.Row="3"
         Grid.Column="0"
        HorizontalOptions="Start"
        VerticalOptions="Center" />
        
    </Grid>
</ContentPage>