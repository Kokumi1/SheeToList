<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SheeToList.MainPage">

    <Grid RowDefinitions="50,*,Auto,50" Padding="30,0">

        <Grid  Grid.Row="0" ColumnDefinitions="*,Auto" Padding="0.10">
            <Label
                    Text="Importer votre google Sheet et
                 obtener votre liste de course"/>
            <Button
                 Text="Importer"
                     Grid.Column="1"
                    HorizontalOptions="End"
                    VerticalOptions="Center" />
        </Grid>
        
        <ScrollView Grid.Row="1">
            <VerticalStackLayout
                Spacing="25">




                <CollectionView x:Name="ItemsList"
                 ItemsSource="{Binding Items}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Text}" VerticalOptions="Center"/>
                                <CheckBox IsChecked="{Binding IsChecked}" Grid.Column="1" VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2" Padding="0.10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                     Text="Révélez tout"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
